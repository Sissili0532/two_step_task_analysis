# 1. Extract reward effect on Common and convert to probability
reward_common <- indiv_models %>%
filter(term %in% c("(Intercept)", "prev_reward")) %>%
select(participant_id, term, estimate) %>%
pivot_wider(names_from = term, values_from = estimate) %>%
rename(intercept = `(Intercept)`,
prev_reward = `prev_reward`) %>%
mutate(
log_odds_rewarded_common = intercept + prev_reward,
prob_rewarded_common = 1 / (1 + exp(-log_odds_rewarded_common))
)
# 2. Compute reward effect on Rare and convert to probability
reward_rare <- indiv_models %>%
filter(term %in% c("(Intercept)", "prev_reward",
"prev_transitionRare",
"prev_reward:prev_transitionRare")) %>%
select(participant_id, term, estimate) %>%
pivot_wider(names_from = term, values_from = estimate) %>%
rename(intercept = `(Intercept)`,
prev_reward = `prev_reward`,
prev_transitionRare = `prev_transitionRare`,
interaction = `prev_reward:prev_transitionRare`) %>%
mutate(
log_odds_rewarded_rare = intercept + prev_reward + prev_transitionRare + interaction,
prob_rewarded_rare = 1 / (1 + exp(-log_odds_rewarded_rare))
)
# 3. Combine into indiv_models_conv_prob
indiv_models_conv_prob <- indiv_models %>%
filter(term == "(Intercept)") %>%
select(participant_id, estimate) %>%
rename(intercept = estimate) %>%
mutate(prob_unrewarded_common = 1 / (1 + exp(-intercept))) %>%
left_join(reward_common %>% select(participant_id, prob_rewarded_common),
by = "participant_id") %>%
left_join(reward_rare %>% select(participant_id, prob_rewarded_rare),
by = "participant_id")
indiv_models_conv_prob
